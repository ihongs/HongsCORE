<?xml version="1.0" encoding="UTF-8"?>
<root>
    <!-- 表单定义 -->
    <form name="test1">
        <field>
            <param name="form-id">test1</param><!-- 快照数据分区 -->
            <param name="part-id">test1</param><!-- 应用数据分区 -->
            <param name="db-name">matrix/data</param><!-- 数据库名称 -->
            <param name="db-path">matrix/data</param><!-- 数据库路径 -->
        </field>
        <field name="id" text="ID" type="hidden">
            <param name="default">@id</param>
            <param name="deforce">create</param>
        </field>
        <field name="name" text="名称" type="text" required="yes">
            <param name="listable">yes</param>
            <param name="filtable">yes</param>
            <param name="minlength">2</param>
            <param name="maxlength">50</param>
        </field>
        <field name="email" text="邮箱" type="email" required="yes">
            <param name="listable">yes</param>
            <param name="pattern">^\w+([-.]\w+)*@\w+([-.]\w+)*$</param>
        </field>
        <field name="phone" text="电话" type="tel">
            <param name="listable">yes</param>
            <param name="pattern">^\+?[0-9][\d\-]+[0-9]$</param>
        </field>
        <field name="status" text="状态" type="select">
            <param name="listable">yes</param><!-- 可列举 -->
            <param name="filtable">yes</param><!-- 可筛查 -->
            <param name="statable">yes</param><!-- 可统计 -->
            <param name="enum">test1-status</param>
            <param name="default">1</param>
        </field>
        <field name="ctime" text="创建时间" type="datetime">
            <param name="listable">yes</param>
            <param name="filtable">yes</param>
            <param name="type">timestamp</param>
            <param name="default">@now</param>
            <param name="deforce">create</param>
        </field>
        <field name="mtime" text="更新时间" type="datetime">
            <param name="listable">yes</param>
            <param name="filtable">yes</param>
            <param name="type">timestamp</param>
            <param name="default">@now</param>
            <param name="deforce">always</param>
        </field>
    </form>
    <!-- 枚举定义 -->
    <enum name="test1-status">
        <value code="1">启用</value>
        <value code="0">禁用</value>
    </enum>
</root>